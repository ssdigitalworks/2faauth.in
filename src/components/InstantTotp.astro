---
import { Icon } from 'astro-icon/components';
---

<div class="rounded-2xl bg-card ring-1 ring-border shadow-sm p-4 sm:p-6" id="totp-container">
  <div class="flex items-center gap-2 mb-5">
    <div class="size-7 rounded-md bg-brand/10 text-brand grid place-items-center">
      <Icon name="heroicons:key" class="size-4" />
    </div>
    <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground font-heading">
      Instant TOTP
    </div>
  </div>

  <label for="secret-input" class="block text-xs font-medium text-muted-foreground mb-2 font-body">
    Paste your secret key
  </label>
  <input
    id="secret-input"
    type="text"
    value="JBSWY3DPEHPK3PXP"
    spellcheck="false"
    autocomplete="off"
    placeholder="e.g. JBSWY3DPEHPK3PXP"
    dir="ltr"
    class="w-full font-mono text-[16px] sm:text-sm tracking-wider px-4 py-3 sm:py-2.5 rounded-md bg-background ring-1 ring-border focus:outline-none focus:ring-2 focus:ring-brand/40 transition"
  />
  <div id="secret-status" class="mt-1.5 text-[11px] text-muted-foreground min-h-[1rem] font-body">
    Valid Base32 secret · RFC 6238 · SHA1 · 6 digits · 30s
  </div>

  <div class="mt-6 rounded-xl bg-muted/40 ring-1 ring-border p-4 sm:p-5">
    <div class="flex flex-col gap-4">
      <div class="min-w-0 w-full">
        <div class="flex items-center justify-between gap-2 mb-2">
          <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-muted-foreground font-heading">
            Current code
          </div>
          <div id="copy-status" class="sm:hidden text-[10px] font-medium uppercase tracking-wider transition-colors text-muted-foreground font-heading" aria-hidden="true">
            Tap to copy
          </div>
        </div>
        <button
          id="mobile-copy-btn"
          type="button"
          aria-label="Copy code"
          class="group block w-full text-start rounded-lg px-3 py-3 -mx-1 sm:mx-0 sm:p-0 sm:rounded-none sm:bg-transparent sm:cursor-default sm:pointer-events-none active:bg-brand/10 transition-colors bg-background/40 sm:bg-transparent min-h-[56px] sm:min-h-0"
        >
          <div id="totp-code" class="font-mono tabular-nums text-4xl sm:text-5xl font-semibold tracking-[0.18em] sm:tracking-[0.12em] whitespace-nowrap text-foreground transition-opacity cursor-pointer" dir="ltr" aria-live="polite">
            ------
          </div>
        </button>
      </div>
      
      <div class="flex items-center gap-2 mt-2 sm:mt-0">
        <button
          id="qr-btn"
          type="button"
          aria-label="Show QR code"
          class="flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 text-[13px] sm:text-xs font-medium px-3 h-11 sm:h-9 rounded-md ring-1 ring-border bg-background hover:bg-muted transition-colors disabled:opacity-40 font-body cursor-pointer"
        >
          <Icon name="heroicons:qr-code" class="size-4 sm:size-3.5 pointer-events-none" />
          QR
        </button>
        <button
          id="copy-btn"
          type="button"
          aria-label="Copy code"
          class="hidden sm:inline-flex items-center justify-center gap-1.5 text-xs font-medium px-3 h-9 rounded-md ring-1 ring-border bg-background hover:bg-muted transition-colors disabled:opacity-40 font-body cursor-pointer"
        >
          <Icon name="heroicons:clipboard-document" id="icon-copy" class="size-3.5 pointer-events-none" />
          <Icon name="heroicons:check" id="icon-check" class="size-3.5 text-brand hidden pointer-events-none" />
          <span id="copy-text" class="pointer-events-none">Copy</span>
        </button>
        <button
          id="save-btn"
          type="button"
          aria-label="Save this account"
          class="flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 text-[13px] sm:text-xs font-medium px-3 h-11 sm:h-9 rounded-md bg-brand/15 text-brand hover:bg-brand/25 transition-colors disabled:opacity-40 border-0 font-body cursor-pointer"
        >
          <Icon name="heroicons:bookmark" class="size-4 sm:size-3.5 pointer-events-none" />
          Save
        </button>
      </div>
    </div>

    <!-- Countdown Progress -->
    <div class="mt-5 flex items-center gap-3">
      <div class="relative flex-1 h-1.5 rounded-full bg-border overflow-hidden">
        <div id="progress-bar" class="absolute rounded-full bg-brand transition-colors duration-200" style="top: 0; bottom: 0; inset-inline-start: 0; width: 100%;"></div>
      </div>
      <div id="time-left" class="font-mono tabular-nums text-xs w-10 text-end transition-colors duration-300 text-muted-foreground">
        30s
      </div>
    </div>

    <!-- QR Reveal -->
    <div id="qr-wrapper" class="grid grid-rows-[0fr] transition-[grid-template-rows,opacity,margin] duration-500 ease-out opacity-0 mt-0">
      <div class="overflow-hidden">
        <div id="qr-container" class="flex flex-col items-center justify-center rounded-lg bg-background ring-1 ring-border p-4 min-h-[176px]">
          <canvas id="qr-canvas" width="160" height="160" class="size-40 hidden"></canvas>
          <p id="qr-hint" class="text-[11px] text-muted-foreground mt-3 text-center hidden font-body whitespace-nowrap">Want a custom name? Save this account first.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { currentCode, isValidSecret, normalizeSecret, otpauthURL } from "@/lib/totp";

  // Prevent multiple bindings and loops across view transitions
  declare global {
    interface Window {
      _totpTickId?: number;
      _tfaEventsBound?: boolean;
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (window._totpTickId) cancelAnimationFrame(window._totpTickId);

  const secretInput = document.getElementById('secret-input') as HTMLInputElement;
  const statusText = document.getElementById('secret-status');
  const codeDisplay = document.getElementById('totp-code');
  const timeLeftDisplay = document.getElementById('time-left');
  const progressBar = document.getElementById('progress-bar');
  
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const mobileCopyBtn = document.getElementById('mobile-copy-btn') as HTMLButtonElement;
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');
  const copyText = document.getElementById('copy-text');
  const mobileCopyStatus = document.getElementById('copy-status');
  
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const qrBtn = document.getElementById('qr-btn') as HTMLButtonElement;
  const qrWrapper = document.getElementById('qr-wrapper');
  const qrContainer = document.getElementById('qr-container');
  const qrCanvas = document.getElementById('qr-canvas') as HTMLCanvasElement;

  const PERIOD = 30;
  let currentSecret = secretInput?.value || '';
  let isValid = true;
  let qrVisible = false;

  function updateValidation() {
    if (!secretInput) return;
    currentSecret = secretInput.value;
    isValid = isValidSecret(currentSecret);
    
    if (!statusText) return;

    if (currentSecret.length === 0) {
      statusText.textContent = "Base32 only (A–Z, 2–7). Nothing leaves your browser.";
    } else if (isValid) {
      statusText.textContent = "Valid Base32 secret · RFC 6238 · SHA1 · 6 digits · 30s";
    } else {
      statusText.textContent = "Invalid Base32 — only letters A–Z and digits 2–7 allowed.";
    }

    [copyBtn, mobileCopyBtn, saveBtn, qrBtn].forEach(btn => {
      if (btn) btn.disabled = !isValid;
    });

    if (!isValid && qrVisible) {
      toggleQr();
    }
  }

  function updateTick() {
    if (!codeDisplay || !timeLeftDisplay || !progressBar) return;

    const now = Date.now();
    const remainingExact = PERIOD - ((now / 1000) % PERIOD);
    const remainingInt = Math.ceil(remainingExact);
    const pct = (remainingExact / PERIOD) * 100;
    const lowTime = remainingInt <= 5;

    // Update Progress
    progressBar.style.width = `${pct}%`;
    progressBar.className = `absolute rounded-full transition-colors duration-200 ${lowTime ? 'bg-destructive' : 'bg-brand'}`;
    
    timeLeftDisplay.textContent = `${remainingInt}s`;
    timeLeftDisplay.className = `font-mono tabular-nums text-xs w-10 text-end transition-colors duration-300 ${lowTime ? 'text-destructive' : 'text-muted-foreground'}`;

    // Update Code
    if (isValid) {
      const code = currentCode({ issuer: "", label: "", secret: normalizeSecret(currentSecret) }, now);
      const formatted = code.match(/.{1,3}/g)?.join(" ") || code;
      
      if (codeDisplay.textContent !== formatted) {
        // Minor animation effect for code change
        codeDisplay.style.opacity = '0.5';
        setTimeout(() => {
          codeDisplay.textContent = formatted;
          codeDisplay.style.opacity = '1';
          codeDisplay.className = 'font-mono tabular-nums text-4xl sm:text-4xl font-semibold tracking-[0.18em] sm:tracking-[0.12em] whitespace-nowrap text-foreground transition-all cursor-pointer select-none';
        }, 150);
      }
    } else {
      codeDisplay.textContent = "------";
      codeDisplay.className = 'font-mono tabular-nums text-4xl sm:text-4xl font-semibold tracking-[0.18em] sm:tracking-[0.12em] whitespace-nowrap text-muted-foreground transition-all cursor-pointer select-none';
    }
    
    window._totpTickId = requestAnimationFrame(updateTick);
  }

  async function handleCopy() {
    if (!isValid || !codeDisplay) return;
    const code = codeDisplay.textContent?.replace(/\s/g, '') || '';
    if (!code || code === '------') return;

    try {
      await navigator.clipboard.writeText(code);
    } catch (e) {
      console.error('Copy failed', e);
    }

    // Pop animation
    const triggerPop = (el: HTMLElement | null) => {
      if (!el) return;
      el.classList.remove('animate-pop');
      void el.offsetWidth; // trigger reflow
      el.classList.add('animate-pop');
    };
    
    triggerPop(copyBtn);
    triggerPop(codeDisplay);
    triggerPop(mobileCopyBtn);

    // Update UI
    if (iconCopy) iconCopy.classList.add('hidden');
    if (iconCheck) iconCheck.classList.remove('hidden');
    if (copyText) {
      copyText.textContent = "Copied";
      copyText.classList.add('text-brand');
    }
    if (mobileCopyStatus) {
      mobileCopyStatus.textContent = "Copied";
      mobileCopyStatus.classList.add('text-brand');
      mobileCopyStatus.classList.remove('text-muted-foreground');
    }

    setTimeout(() => {
      if (iconCopy) iconCopy.classList.remove('hidden');
      if (iconCheck) iconCheck.classList.add('hidden');
      if (copyText) {
        copyText.textContent = "Copy";
        copyText.classList.remove('text-brand');
      }
      if (mobileCopyStatus) {
        mobileCopyStatus.textContent = "Tap to copy";
        mobileCopyStatus.classList.remove('text-brand');
        mobileCopyStatus.classList.add('text-muted-foreground');
      }
    }, 1500);
  }

  async function toggleQr() {
    qrVisible = !qrVisible;
    if (!qrWrapper || !qrCanvas) return;

    if (qrVisible) {
      qrWrapper.classList.remove('grid-rows-[0fr]', 'opacity-0', 'mt-0');
      qrWrapper.classList.add('grid-rows-[1fr]', 'opacity-100', 'mt-5');
      
      const url = otpauthURL({ 
        issuer: "", 
        label: "2faauth.in",
        secret: normalizeSecret(currentSecret), 
        period: PERIOD, 
        digits: 6, 
        algorithm: "SHA1" 
      });
      
      // Calculate QR code colors based on theme
      const isDark = document.documentElement.classList.contains('dark');
      const fgColor = isDark ? '#ffffff' : '#000000';
      const bgColor = 'transparent';

      qrCanvas.classList.remove('hidden');
      const hint = document.getElementById('qr-hint');
      if (hint) hint.classList.remove('hidden');

      try {
        const { default: QRCode } = await import('qrcode');
        if (qrVisible) {
          QRCode.toCanvas(qrCanvas, url, {
            width: 160,
            margin: 1,
            color: { dark: fgColor, light: '#00000000' }
          });
        }
      } catch (err) {
        console.error("QR Error:", err);
      }
      qrBtn.setAttribute('aria-pressed', 'true');
    } else {
      qrWrapper.classList.add('grid-rows-[0fr]', 'opacity-0', 'mt-0');
      qrWrapper.classList.remove('grid-rows-[1fr]', 'opacity-100', 'mt-5');
      qrBtn.setAttribute('aria-pressed', 'false');
    }
  }

  function handleSave() {
    if (!isValid) return;
    if (typeof navigator !== "undefined" && navigator.vibrate) {
      navigator.vibrate(50);
    }
    const event = new CustomEvent('tfa:open-save', {
      detail: { secret: normalizeSecret(currentSecret), defaultName: '' }
    });
    document.dispatchEvent(event);
  }

  // Event Listeners
  codeDisplay?.addEventListener('click', handleCopy);

  secretInput?.addEventListener('input', () => {
    updateValidation();
    if (qrVisible) toggleQr(); // Redraw if visible
  });

  copyBtn?.addEventListener('click', handleCopy);
  mobileCopyBtn?.addEventListener('click', handleCopy);
  saveBtn?.addEventListener('click', handleSave);
  qrBtn?.addEventListener('click', toggleQr);

  // Listen for the 'Use Code' event from the Saved Accounts Drawer
  if (!window._tfaEventsBound) {
    document.addEventListener('tfa:use-secret', ((e: CustomEvent) => {
      const input = document.getElementById('secret-input') as HTMLInputElement | null;
      if (input) {
        input.value = e.detail.secret;
        // Trigger input event so the current active closure's validation runs
        input.dispatchEvent(new Event('input'));
      }
    }) as EventListener);
    window._tfaEventsBound = true;
  }

  // Initial setup
  updateValidation();
  window._totpTickId = requestAnimationFrame(updateTick);
  });
</script>
