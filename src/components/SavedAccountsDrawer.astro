---
import { Icon } from 'astro-icon/components';
---

<!-- Saved Accounts Drawer (using native dialog) -->
<dialog id="saved-drawer" class="fixed left-0 top-0 h-full max-h-none w-full max-w-sm m-0 bg-background text-foreground shadow-2xl backdrop:bg-background/80 backdrop:backdrop-blur-sm border-r border-border rounded-none p-0">
  <div class="flex flex-col h-full w-full">
    <div class="flex items-center justify-between p-4 border-b border-border">
      <h2 class="text-lg font-heading font-semibold">Saved Accounts</h2>
      <button id="close-drawer" class="size-8 grid place-items-center rounded-md hover:bg-muted text-muted-foreground hover:text-foreground">
        <Icon name="heroicons:x-mark" class="size-5" />
      </button>
    </div>
    
    <div class="p-4 border-b border-border">
      <div class="relative">
        <Icon name="heroicons:magnifying-glass" class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-muted-foreground" />
        <input 
          type="text" 
          id="saved-search" 
          aria-label="Search saved accounts"
          placeholder="Search accounts..." 
          class="w-full pl-9 pr-4 py-2 bg-muted/50 border border-border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent font-body"
        />
      </div>
    </div>

    <div id="saved-list" class="flex-1 overflow-y-auto p-4 space-y-3">
      <!-- Accounts will be rendered here by JS -->
      <div id="empty-state" class="hidden flex-col items-center justify-center h-40 text-center space-y-3 text-muted-foreground">
        <Icon name="heroicons:bookmark-slash" class="size-8 opacity-20" />
        <p class="text-sm font-body">No saved accounts yet.<br/>Generate and save a code to see it here.</p>
      </div>
    </div>
  </div>
</dialog>

<!-- Save Account Modal -->
<dialog id="save-modal" class="m-auto bg-background text-foreground shadow-xl rounded-xl border border-border p-0 w-full max-w-md backdrop:bg-black/50 backdrop:backdrop-blur-sm">
  <form id="save-form" method="dialog" class="flex flex-col">
    <div class="p-5 border-b border-border">
      <h2 class="text-lg font-heading font-semibold flex items-center gap-2">
        <Icon name="heroicons:bookmark" class="size-5 text-brand" />
        Save Account
      </h2>
    </div>
    
    <div class="p-5 space-y-4">
      <div>
        <label for="account-name" class="block text-sm font-medium mb-1 font-body">Account Name</label>
        <input 
          type="text" 
          id="account-name" 
          placeholder="e.g. Google, GitHub" 
          class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand font-body"
        />
      </div>
      <div>
        <label for="account-secret" class="block text-sm font-medium mb-1 font-body">Secret Key</label>
        <input 
          type="text" 
          id="account-secret" 
          required
          readonly
          class="w-full px-3 py-2 bg-muted/50 border border-border rounded-md text-sm font-mono text-muted-foreground cursor-not-allowed"
        />
      </div>
    </div>

    <div class="p-5 bg-muted/30 border-t border-border flex justify-end gap-3 rounded-b-xl">
      <button type="button" id="cancel-save" class="px-4 py-2 text-sm font-medium rounded-md hover:bg-muted font-body">
        Cancel
      </button>
      <button type="submit" class="px-4 py-2 text-sm font-medium bg-brand text-brand-foreground rounded-md hover:bg-brand/90 font-body">
        Save Account
      </button>
    </div>
  </form>
</dialog>

<script>
  import { currentCode, normalizeSecret, otpauthURL } from "@/lib/totp";

  // Simple state management for saved accounts using localStorage
  const PLAIN_KEY = "tfa.saved-accounts.v1";
  
  function getSavedAccounts() {
    try {
      const parsed = JSON.parse(localStorage.getItem(PLAIN_KEY) ?? "[]");
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function saveAccount(account) {
    const accounts = getSavedAccounts();
    accounts.push({ ...account, id: Date.now().toString(), createdAt: Date.now() });
    localStorage.setItem(PLAIN_KEY, JSON.stringify(accounts));
    document.dispatchEvent(new CustomEvent('tfa:render-accounts'));
  }

  function deleteAccount(id) {
    const accounts = getSavedAccounts();
    const updated = accounts.filter(a => a.id !== id);
    localStorage.setItem(PLAIN_KEY, JSON.stringify(updated));
    document.dispatchEvent(new CustomEvent('tfa:render-accounts'));
  }

  // Store interval on window so it survives Astro page transitions
  
  // We attach global listeners only once per SPA session, 
  // but they will reference the currently active DOM elements.
  if (!(window as any)._tfaGlobalEvents) {
    document.addEventListener('tfa:open-drawer', () => {
      const drawer = document.getElementById('saved-drawer') as HTMLDialogElement;
      drawer?.showModal();
      document.dispatchEvent(new CustomEvent('tfa:render-accounts'));
      document.body.style.overflow = 'hidden';
    });

    document.addEventListener('tfa:open-save', ((e: CustomEvent) => {
      const { secret, defaultName } = e.detail;
      const accountSecretInput = document.getElementById('account-secret') as HTMLInputElement;
      const accountNameInput = document.getElementById('account-name') as HTMLInputElement;
      const saveModal = document.getElementById('save-modal') as HTMLDialogElement;
      
      if (accountSecretInput) accountSecretInput.value = secret;
      if (accountNameInput) accountNameInput.value = defaultName || '';
      saveModal?.showModal();
    }) as EventListener);

    const triggerDrawerRender = () => {
      const searchInput = document.getElementById('saved-search') as HTMLInputElement | null;
      if (searchInput) searchInput.dispatchEvent(new Event('input'));
    };

    document.addEventListener('tfa:account-saved', triggerDrawerRender);
    document.addEventListener('tfa:render-accounts', triggerDrawerRender);

    (window as any)._tfaGlobalEvents = true;
  }

  document.addEventListener('astro:page-load', () => {
    const drawer = document.getElementById('saved-drawer') as HTMLDialogElement;
    const closeBtn = document.getElementById('close-drawer');
    const searchInput = document.getElementById('saved-search') as HTMLInputElement;
    const listContainer = document.getElementById('saved-list');
    const emptyState = document.getElementById('empty-state');
    
    const saveModal = document.getElementById('save-modal') as HTMLDialogElement;
    const saveForm = document.getElementById('save-form') as HTMLFormElement;
    const accountNameInput = document.getElementById('account-name') as HTMLInputElement;
    const accountSecretInput = document.getElementById('account-secret') as HTMLInputElement;
    const cancelSaveBtn = document.getElementById('cancel-save');

    closeBtn?.addEventListener('click', () => {
      drawer?.close();
    });

    drawer?.addEventListener('close', () => {
      document.body.style.overflow = '';
    });

    // Click outside to close drawer
    drawer?.addEventListener('click', (e) => {
      const rect = drawer.getBoundingClientRect();
      if (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom) {
        drawer.close();
      }
    });

    cancelSaveBtn?.addEventListener('click', () => {
      saveModal?.close();
    });

    saveForm?.addEventListener('submit', (e) => {
      let title = accountNameInput.value.trim();
      if (!title) title = "Untitled";

      saveAccount({
        title,
        secret: accountSecretInput.value
      });
      document.dispatchEvent(new CustomEvent('tfa:account-saved'));
    });

    // Click outside to close save modal
    saveModal?.addEventListener('click', (e) => {
      const rect = saveModal.getBoundingClientRect();
      if (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom) {
        saveModal.close();
      }
    });

    // Search logic
    searchInput?.addEventListener('input', () => {
      renderAccounts(searchInput.value);
    });

    function renderAccounts(searchQuery = "") {
      if (!listContainer || !emptyState) return;
      
      const accounts = getSavedAccounts();
      const filtered = accounts.filter(a => 
        a.title.toLowerCase().includes(searchQuery.toLowerCase())
      );

      // Clear list (except empty state)
      const children = Array.from(listContainer.children);
      children.forEach(child => {
        if (child.id !== 'empty-state') {
          listContainer.removeChild(child);
        }
      });

      if (filtered.length === 0) {
        if (searchQuery) {
          emptyState.classList.add('hidden'); // could show "no results" state instead
        } else {
          emptyState.classList.remove('hidden');
          emptyState.classList.add('flex');
        }
        return;
      }

      emptyState.classList.add('hidden');
      emptyState.classList.remove('flex');

      filtered.forEach(account => {
        const item = document.createElement('div');
        item.className = 'p-3 rounded-lg border border-border bg-card flex items-center justify-between group';
        
        // Sanitize
        const safeTitle = document.createElement('span');
        safeTitle.className = 'font-medium font-heading truncate';
        safeTitle.textContent = account.title;
        
        const safeSecret = document.createElement('span');
        safeSecret.className = 'text-xs text-muted-foreground font-mono truncate mt-0.5';
        const formattedSecret = account.secret.match(/.{1,4}/g)?.join(" ") || account.secret;
        safeSecret.textContent = formattedSecret;

        item.innerHTML = `
          <div class="flex flex-col w-full">
            <div class="flex justify-between items-start w-full">
              <div class="flex flex-col overflow-hidden safe-title-container">
              </div>
              <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity ml-2 shrink-0">
                <button class="qr-btn p-1.5 text-brand hover:bg-brand/10 rounded-md" title="Show QR Code">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
                </button>
                <button class="use-btn p-1.5 text-brand hover:bg-brand/10 rounded-md" title="Use in main generator">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
                <button class="del-btn p-1.5 text-destructive hover:bg-destructive/10 rounded-md" title="Delete">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </div>
            </div>
            <button type="button" aria-label="Copy code" class="w-full mt-4 bg-background/50 rounded-md p-3 border border-border/50 flex items-center justify-between group/code cursor-pointer copy-inline-btn transition-colors hover:bg-background/80" title="Click to copy code">
              <div class="totp-display font-mono text-3xl font-semibold tracking-[0.15em] text-foreground" data-secret="${account.secret}">------</div>
              <div class="flex items-center gap-3">
                <div class="drawer-timer text-xs font-medium text-brand/80 w-5 text-right font-mono" aria-hidden="true"></div>
                <div class="text-muted-foreground group-hover/code:text-brand transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                </div>
              </div>
            </button>
            <div class="qr-wrapper grid grid-rows-[0fr] opacity-0 transition-all duration-300">
              <div class="overflow-hidden">
                <div class="mt-4 flex items-center justify-center rounded-lg bg-background ring-1 ring-border p-4">
                  <canvas class="qr-canvas size-32 hidden"></canvas>
                </div>
              </div>
            </div>
          </div>
        `;
        
        const container = item.querySelector('.safe-title-container');
        if (container) {
          container.appendChild(safeTitle);
          container.appendChild(safeSecret);
        }
        item.querySelector('.del-btn')?.addEventListener('click', () => {
          if (confirm('Delete this account?')) {
            deleteAccount(account.id);
          }
        });

        let qrVisible = false;
        item.querySelector('.qr-btn')?.addEventListener('click', async () => {
          qrVisible = !qrVisible;
          const wrapper = item.querySelector('.qr-wrapper');
          const canvas = item.querySelector('.qr-canvas');
          if (!wrapper || !canvas) return;

          if (qrVisible) {
            wrapper.classList.remove('grid-rows-[0fr]', 'opacity-0');
            wrapper.classList.add('grid-rows-[1fr]', 'opacity-100');
            
            const url = otpauthURL({
              issuer: "",
              label: "2faauth.in : " + account.title,
              secret: normalizeSecret(account.secret),
              period: 30,
              digits: 6,
              algorithm: "SHA1"
            });
            const isDark = document.documentElement.classList.contains('dark');
            canvas.classList.remove('hidden');
            try {
              const { default: QRCode } = await import('qrcode');
              if (qrVisible) {
                QRCode.toCanvas(canvas, url, {
                  width: 128,
                  margin: 1,
                  color: { dark: isDark ? '#ffffff' : '#000000', light: '#00000000' }
                });
              }
            } catch (err) {
              console.error("QR Error:", err);
            }
          } else {
            wrapper.classList.remove('grid-rows-[1fr]', 'opacity-100');
            wrapper.classList.add('grid-rows-[0fr]', 'opacity-0');
          }
        });

        const useAction = () => {
          document.dispatchEvent(new CustomEvent('tfa:use-secret', { detail: { secret: account.secret } }));
          drawer?.close();
        };

        item.querySelector('.use-btn')?.addEventListener('click', useAction);
        
        item.querySelector('.copy-inline-btn')?.addEventListener('click', async (e) => {
          const btn = e.currentTarget as HTMLElement;
          const display = btn.querySelector('.totp-display');
          const code = display?.textContent?.replace(/\s/g, '') || '';
          if (code && code !== '------') {
            try {
              await navigator.clipboard.writeText(code);
              const originalBg = btn.className;
              btn.classList.add('ring-1', 'ring-brand', 'bg-brand/10');
              
              btn.classList.remove('animate-pop');
              void btn.offsetWidth; // trigger reflow
              btn.classList.add('animate-pop');

              setTimeout(() => {
                btn.className = originalBg;
              }, 400);
            } catch (err) {
              console.error('Failed to copy', err);
            }
          }
        });
        
        listContainer.appendChild(item);
      });
      
      updateDrawerCodes();
    }

    function updateDrawerCodes() {
      const displays = document.querySelectorAll('.totp-display');
      const timers = document.querySelectorAll('.drawer-timer');
      if (displays.length === 0) return;
      
      const now = Date.now();
      const timeLeft = 30 - Math.floor((now / 1000) % 30);
      const timeText = `${timeLeft}s`;

      displays.forEach(el => {
        const secret = el.getAttribute('data-secret');
        if (secret) {
          const code = currentCode({ issuer: "", label: "", secret: normalizeSecret(secret) }, now);
          const formatted = code.match(/.{1,3}/g)?.join(" ") || code;
          if (el.textContent !== formatted) {
            el.textContent = formatted;
          }
        }
      });

      timers.forEach(el => {
        if (el.textContent !== timeText) {
          el.textContent = timeText;
          if (timeLeft <= 5) {
            el.classList.add('text-destructive');
            el.classList.remove('text-brand/80');
          } else {
            el.classList.add('text-brand/80');
            el.classList.remove('text-destructive');
          }
        }
      });
    }

    if ((window as any)._drawerIntervalId) clearInterval((window as any)._drawerIntervalId);
    (window as any)._drawerIntervalId = setInterval(updateDrawerCodes, 500);
    document.addEventListener('astro:before-swap', () => {
      if ((window as any)._drawerIntervalId) clearInterval((window as any)._drawerIntervalId);
    }, { once: true });
  });
</script>
