---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getBlogPosts, saveBlogPost, deleteBlogPost } from '@/lib/db';
import { verifyAdminSession } from '@/lib/session';

const sessionToken = Astro.cookies.get("admin_session")?.value;
if (!await verifyAdminSession(sessionToken)) {
  return Astro.redirect("/auth");
}

let saved = false;
let deleted = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action')?.toString();
  
  if (action === 'delete') {
    const id = data.get('id')?.toString();
    if (id) {
      await deleteBlogPost(id);
      deleted = true;
    }
  } else if (action === 'save') {
    const id = data.get('id')?.toString() || Date.now().toString();
    const title = data.get('title')?.toString() || 'Untitled Post';
    // Generate a slug from the title if one isn't provided or if it's new
    let slug = data.get('slug')?.toString();
    if (!slug) {
      slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }
    const excerpt = data.get('excerpt')?.toString() || '';
    const content = data.get('content')?.toString() || '';
    const date = data.get('date')?.toString() || new Date().toISOString().split('T')[0];

    await saveBlogPost({ id, title, slug, excerpt, content, date });
    saved = true;
  }
}

const rawPosts = await getBlogPosts();
const posts = rawPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<AdminLayout title="Blog Management | Admin" activeTab="blog">
  <h1 class="text-3xl font-bold font-heading mb-6">Blog Manager</h1>
        
        {saved && (
          <div class="mb-6 p-4 rounded-md bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-sm font-medium">
            Blog post saved successfully!
          </div>
        )}
        
        {deleted && (
          <div class="mb-6 p-4 rounded-md bg-destructive/10 border border-destructive/20 text-destructive text-sm font-medium">
            Blog post deleted successfully!
          </div>
        )}

        <div class="rounded-xl border border-border bg-card shadow-sm p-6 mb-8">
          <h2 class="text-xl font-semibold mb-4 font-heading">Write New Post</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="save" />
            <input type="hidden" name="id" value="" />
            
            <div class="grid gap-4 sm:grid-cols-3">
              <div>
                <label class="block text-sm font-medium mb-1">Title</label>
                <input type="text" id="form-title" name="title" required class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm focus:ring-2 focus:ring-brand" placeholder="Post Title" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Slug (optional)</label>
                <input type="text" id="form-slug" name="slug" class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm focus:ring-2 focus:ring-brand" placeholder="post-url-slug" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Date</label>
                <input type="date" id="form-date" name="date" value={new Date().toISOString().split('T')[0]} class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm focus:ring-2 focus:ring-brand" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Excerpt</label>
              <textarea id="form-excerpt" name="excerpt" rows="2" class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm focus:ring-2 focus:ring-brand" placeholder="A short summary of the post..."></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Content (Markdown)</label>
              <textarea id="form-content" name="content" required rows="10" class="w-full px-3 py-2 bg-background border border-border rounded-md text-sm font-mono focus:ring-2 focus:ring-brand" placeholder="Write your post content here using Markdown formatting..."></textarea>
            </div>

            <div class="flex items-center justify-between pt-2">
              <button type="button" id="cancel-edit-btn" class="hidden px-4 py-2 text-sm font-medium rounded-md hover:bg-muted transition-colors font-body" onclick="resetBlogForm()">Cancel Edit</button>
              <button type="submit" id="submit-btn" class="ml-auto px-4 py-2 bg-brand text-brand-foreground font-medium rounded-md hover:bg-brand/90 transition-colors">
                Publish Post
              </button>
            </div>
          </form>
        </div>

        <div class="rounded-xl border border-border bg-card shadow-sm p-6">
          <h2 class="text-xl font-semibold mb-4 font-heading">Published Posts</h2>
          {posts.length === 0 ? (
            <p class="text-sm text-muted-foreground">No posts published yet.</p>
          ) : (
            <div class="space-y-4 divide-y divide-border">
              {posts.map(post => (
                <div class="pt-4 first:pt-0 flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center">
                  <div>
                    <h3 class="font-medium text-foreground">{post.title}</h3>
                    <p class="text-sm text-muted-foreground">/{post.slug} • {post.date}</p>
                  </div>
                  <div class="flex gap-2">
                    <a href={`/blog/${post.slug}`} target="_blank" class="px-3 py-1.5 text-xs font-medium bg-muted text-foreground rounded-md hover:bg-muted/80">
                      View
                    </a>
                    <button
                      type="button"
                      class="edit-post-btn px-3 py-1.5 text-xs font-medium bg-brand/10 text-brand rounded-md hover:bg-brand/20"
                      data-id={post.id}
                      data-title={post.title}
                      data-slug={post.slug}
                      data-excerpt={post.excerpt}
                      data-content={post.content}
                      data-date={post.date}
                    >
                      Edit
                    </button>
                    <form method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this post?');">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={post.id} />
                      <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-destructive/10 text-destructive rounded-md hover:bg-destructive/20">
                        Delete
                      </button>
                    </form>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
</AdminLayout>

<script>
  function resetBlogForm() {
    const form = document.querySelector('form[method="POST"]') as HTMLFormElement;
    const idInput = form?.querySelector('input[name="id"]') as HTMLInputElement;
    const titleInput = document.getElementById('form-title') as HTMLInputElement;
    const slugInput = document.getElementById('form-slug') as HTMLInputElement;
    const dateInput = document.getElementById('form-date') as HTMLInputElement;
    const excerptInput = document.getElementById('form-excerpt') as HTMLTextAreaElement;
    const contentInput = document.getElementById('form-content') as HTMLTextAreaElement;
    const submitBtn = document.getElementById('submit-btn');
    const cancelBtn = document.getElementById('cancel-edit-btn');
    const heading = form?.closest('.rounded-xl')?.querySelector('h2');

    if (idInput) idInput.value = '';
    if (titleInput) titleInput.value = '';
    if (slugInput) slugInput.value = '';
    if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];
    if (excerptInput) excerptInput.value = '';
    if (contentInput) contentInput.value = '';
    if (submitBtn) submitBtn.textContent = 'Publish Post';
    if (cancelBtn) cancelBtn.classList.add('hidden');
    if (heading) heading.textContent = 'Write New Post';
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.edit-post-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const form = document.querySelector('form[method="POST"]') as HTMLFormElement;
        const idInput = form?.querySelector('input[name="id"]') as HTMLInputElement;
        const titleInput = document.getElementById('form-title') as HTMLInputElement;
        const slugInput = document.getElementById('form-slug') as HTMLInputElement;
        const dateInput = document.getElementById('form-date') as HTMLInputElement;
        const excerptInput = document.getElementById('form-excerpt') as HTMLTextAreaElement;
        const contentInput = document.getElementById('form-content') as HTMLTextAreaElement;
        const submitBtn = document.getElementById('submit-btn');
        const cancelBtn = document.getElementById('cancel-edit-btn');
        const heading = form?.closest('.rounded-xl')?.querySelector('h2');

        if (idInput) idInput.value = el.dataset.id || '';
        if (titleInput) titleInput.value = el.dataset.title || '';
        if (slugInput) slugInput.value = el.dataset.slug || '';
        if (dateInput) dateInput.value = el.dataset.date || '';
        if (excerptInput) excerptInput.value = el.dataset.excerpt || '';
        if (contentInput) contentInput.value = el.dataset.content || '';
        if (submitBtn) submitBtn.textContent = 'Update Post';
        if (cancelBtn) cancelBtn.classList.remove('hidden');
        if (heading) heading.textContent = 'Edit Post';

        form?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  });
</script>
