---
import Layout from '../layouts/Layout.astro';
import LandingNav from '@/components/LandingNav.astro';
import LandingFooter from '@/components/LandingFooter.astro';
---

<Layout title="404 — Page Not Found | 2FA auth">
  <div class="relative min-h-screen bg-background text-foreground flex flex-col">
    <LandingNav />
    <main class="flex-1 flex flex-col items-center justify-center px-5 py-20 text-center">
      <p class="text-8xl font-extrabold font-heading text-brand/20 select-none">404</p>
      <h1 class="mt-4 text-3xl font-bold font-heading text-foreground">Page not found</h1>
      <p class="mt-4 text-muted-foreground font-body max-w-sm">
        The page you're looking for doesn't exist or may have been moved.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-2.5 rounded-md bg-brand text-brand-foreground font-medium text-sm hover:bg-brand/90 transition-colors font-body"
        >
          ← Back to Home
        </a>
        <a
          href="/blog"
          class="inline-flex items-center justify-center px-6 py-2.5 rounded-md bg-muted text-foreground font-medium text-sm hover:bg-muted/80 transition-colors font-body"
        >
          Read the Blog
        </a>
      </div>
    </main>
    <LandingFooter />
  </div>
</Layout>
