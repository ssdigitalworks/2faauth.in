---
import { getBlogPosts } from '@/lib/db';
import LandingNav from '@/components/LandingNav.astro';
import LandingFooter from '@/components/LandingFooter.astro';
import Layout from '@/layouts/Layout.astro';

const rawPosts = await getBlogPosts();
const posts = rawPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "2FA auth Blog",
  url: "/blog",
  isPartOf: { "@type": "WebSite", name: "2FA auth", url: "/" },
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.title,
    description: p.excerpt,
    datePublished: p.date,
    url: `/blog/${p.slug}`,
  })),
};
---

<Layout title="Blog — 2FA auth" description="Articles on TOTP, RFC 6238, two-factor authentication, and client-side security — written for developers and the security-curious.">
  <div class="relative min-h-screen bg-background text-foreground flex flex-col">
    <script type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />
    <LandingNav />
    <main class="flex-1 px-5 sm:px-6 py-14">
      <section class="max-w-3xl mx-auto">
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight font-heading">Blog</h1>
        <p class="mt-4 text-base text-muted-foreground leading-relaxed font-body">
          Short, practical posts on TOTP, two-factor authentication, and the tradeoffs behind
          client-side security tools.
        </p>
        
        {posts.length === 0 ? (
          <div class="mt-10 p-8 text-center border border-dashed border-border rounded-xl">
            <p class="text-muted-foreground">No blog posts have been published yet.</p>
          </div>
        ) : (
          <ul class="mt-10 divide-y divide-border">
            {posts.map((p) => (
              <li class="py-6">
                <a href={`/blog/${p.slug}`} class="group block">
                  <p class="text-[11px] uppercase tracking-widest text-muted-foreground font-body">
                    {new Date(p.date).toLocaleDateString(undefined, {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                  <h2 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-brand transition-colors font-heading">
                    {p.title}
                  </h2>
                  <p class="mt-2 text-sm text-muted-foreground leading-7 font-body">{p.excerpt}</p>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <LandingFooter />
  </div>
</Layout>
